PORT=3000
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=loyalcloud_db
JWT_SECRET=your_super_secret_key_here

# อีเมล (ลืมรหัสผ่าน) — Gmail + App Password 16 ตัว
# EMAIL_USER=
# EMAIL_APP_PASSWORD=
# ถ้า SMTP error เรื่อง certificate บน Windows: SMTP_TLS_INSECURE=1

# ลิงก์ในอีเมลรีเซ็ต — ควรเป็น URL ของ Flutter Web (ไม่ใช่พอร์ต API)
# ตัวอย่าง: http://localhost:8080  (รัน: flutter run -d chrome --web-port=8080)
# FRONTEND_URL=http://localhost:8080

# ถ้า FRONTEND_URL ชี้ไปพอร์ต API โดยผิด (เช่น :3001) — ตั้งค่านี้แล้วคลิกลิงก์จะ redirect ไป Flutter Web
# FRONTEND_WEB_URL=http://localhost:8080
