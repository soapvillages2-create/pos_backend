# คัดลอกเป็นไฟล์ `.env` บน VPS (อยู่โฟลเดอร์เดียวกับ docker-compose.yml)
# คำสั่ง: cp .env.docker.example .env แล้วแก้ค่าให้เป็นความลับจริง
#
# ห้าม commit ไฟล์ `.env` ขึ้น Git

# --- Backend (container ฟังพอร์ตภายใน 3001 — ตรงกับ nginx) ---
PORT=3001
NODE_ENV=production

# --- PostgreSQL (ใช้ร่วมกับ service `db` ใน docker-compose) ---
# DB_HOST / DB_PORT ถูก override ใน docker-compose เป็น db:5432 — ไม่ต้องพึ่งค่าที่บรรทัดนี้ตอนรัน Docker
DB_HOST=localhost
DB_PORT=5432
DB_USER=loyalcloud
DB_PASSWORD=เปลี่ยนเป็นรหัสผ่านยาวและสุ่ม
DB_NAME=loyalcloud_db

# --- JWT ---
JWT_SECRET=สร้างสตริงยาวสุ่มอย่างน้อย_32_ตัว_สำหรับ_production

# --- สร้าง admin คนแรก (ใช้กับ npm run create-admin ชั่วคราว แล้วลบออก) ---
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# ADMIN_STORE_NAME=ร้านหลัก
# ADMIN_PROVINCE=กรุงเทพมหานคร
# ADMIN_COUNTRY=ประเทศไทย
# ADMIN_FULL_NAME=

# --- อีเมล (ลืมรหัสผ่าน) ---
EMAIL_USER=
EMAIL_APP_PASSWORD=
# SMTP_TLS_INSECURE=1

# --- CORS (ถ้าไม่ตั้ง = อนุญาตทุก origin — เหมาะกับ dev / แอป desktop) ---
# Flutter Web หรือเว็บที่โดเมนจำกัด: คั่นหลายโดเมนด้วย comma
# CORS_ORIGIN=https://app.loyalcloudcrm.com,https://loyalcloudcrm.com

# --- URL สาธารณะ (สำหรับลิงก์ในอีเมล / redirect) ---
# ใช้ https หลังติดตั้ง SSL แล้ว
FRONTEND_URL=https://api.loyalcloudcrm.com
# FRONTEND_WEB_URL=https://app.loyalcloudcrm.com
